{
  "name": "utilitix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:client": "pnpm --filter @utilitix/client dev",
    "dev:server": "pnpm --filter @utilitix/server dev",
    "build:client": "pnpm --filter @utilitix/client build",
    "build:db": "pnpm --filter @utilitix/db build",
    "build:server": "pnpm --filter @utilitix/db build && pnpm --filter @utilitix/server build",
    "start:client": "pnpm --filter @utilitix/client start",
    "start:server": "pnpm --filter @utilitix/server start",
    "db:up": "docker compose -f packages/db/docker-compose.yml up -d",
    "db:down": "docker compose -f packages/db/docker-compose.yml down",
    "db:generate": "pnpm --filter @utilitix/db db:generate",
    "db:migrate": "pnpm --filter @utilitix/db db:migrate",
    "db:push": "pnpm --filter @utilitix/db db:push",
    "db:studio": "pnpm --filter @utilitix/db db:studio"
  }
}
